# ============================================================
# AgentFlow - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
APP_NAME=AgentFlow
APP_VERSION=1.0.0
DEBUG=false
PORT=8000

# Database (Railway auto-sets DATABASE_URL when PostgreSQL is added)
DATABASE_URL=postgresql://agentflow:agentflow@localhost:5433/agentflow

# Redis (Railway auto-sets REDIS_URL when Redis is added)
REDIS_URL=redis://localhost:6379/0

# Security - CHANGE THIS before deploying!
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# AI Providers (at least one required for LLM agent)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434  # for local models
DEFAULT_MODEL=gpt-4o-mini

# Stripe (required for billing features)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# App URL (used for Stripe redirect URLs)
APP_URL=https://your-domain.com

# Email Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@your-domain.com

# Usage Limits Per Plan (runs/month)
STARTER_RUNS=100
PRO_RUNS=1000
ENTERPRISE_RUNS=10000
